{
  "name": "esday-demo-react",
  "version": "0.6.3",
  "description": "Minimal demo for using the esday library in a basic React app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BePo65/esday-demo-react.git"
  },
  "keywords": [
    "esday",
    "demo",
    "react",
    "date",
    "time",
    "immutable",
    "moment",
    "dayjs",
    "format"
  ],
  "author": "BePo65",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/BePo65/esday-demo-react/issues"
  },
  "homepage": "https://github.com/BePo65/esday-demo-react#readme",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite --open --port 3000",
    "build": "vite build",
    "build:ghpages": "vite build --base=/esday-demo-react/ && del-cli ghpages && cpy \"dist/**\" ghpages && cpy README.md ghpages  && cpy LICENSE ghpages",
    "lint": "npm exec biome check .",
    "lint:fix": "npm exec biome check --write .",
    "preview": "vite preview --open"
  },
  "dependencies": {
    "esday": "^0.6.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "cpy-cli": "^7.0.0",
    "del-cli": "^7.0.0",
    "globals": "^17.5.0",
    "vite": "^7.3.1"
  }
}
